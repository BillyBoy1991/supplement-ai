# ── Base de datos ──────────────────────────────────────────────────────────────
# Para Docker Compose (dev): usa el hostname del servicio "db"
DATABASE_URL=postgresql+psycopg://supplement_user:supplement_pass@db:5432/supplement_ai

# Credenciales del contenedor Postgres (deben coincidir con DATABASE_URL)
POSTGRES_USER=supplement_user
POSTGRES_PASSWORD=supplement_pass

# ── Autenticación JWT ──────────────────────────────────────────────────────────
# Genera un secreto seguro: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro
JWT_EXPIRE_MINUTES=60

# ── LLM (OpenRouter) ───────────────────────────────────────────────────────────
# Crea tu cuenta en https://openrouter.ai y genera una API key
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Modelo gratuito. Ver catálogo en https://openrouter.ai/models?q=free
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free
# URL base del endpoint OpenAI-compatible (normalmente no hace falta cambiarla)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── CORS ───────────────────────────────────────────────────────────────────────
# Lista separada por comas. En prod: solo el dominio de producción
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# ── Entorno ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
